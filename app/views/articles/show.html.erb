<h1 class="bg-blue-500 text-white p-2 rounded-lg text-lg font-semibold mb-4">
  <%= @article.title %>
</h1>

<p class="text-gray-700 text-lg leading-relaxed mb-6">
  <%= @article.body %>
</p>

<ul class="flex space-x-4">
  <li>
    <%= link_to "Edit", edit_article_path(@article), class: "inline-block px-4 py-2 bg-indigo-500 text-white rounded hover:bg-indigo-600 transition" %>
  </li>
  <li>
    <%= link_to "Destroy", article_path(@article), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "inline-block px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 transition" %>
  </li>
</ul>
<div><%= link_to "Back to Articles", articles_path %></div>
