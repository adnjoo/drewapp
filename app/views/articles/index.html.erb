<h1 class="text-3xl font-bold mb-6">Articles</h1>
<ul class="space-y-2">
  <% @articles.each do |article| %>
    <li>
      <%= link_to article.title, article, class: "text-blue-500 hover:underline" %>
    </li>
  <% end %>
</ul>
<div class="mt-4">
  <% if user_signed_in? %>
    <%= link_to "New Article", new_article_path, class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
    <p class="text-green-500 mt-4">You are signed in as <%= current_user.email %>.</p>
    <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-red-500 hover:underline" %>
  <% else %>
    <p class="text-red-500 mt-4">You are not signed in.</p>
    <%= link_to "Sign In", new_user_session_path, class: "text-blue-500 hover:underline" %>
    <%= link_to "Sign Up", new_user_registration_path, class: "text-blue-500 hover:underline ml-4" %>
  <% end %>
</div>
