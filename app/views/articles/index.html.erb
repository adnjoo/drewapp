<h1 class="text-3xl font-bold mb-6">Articles</h1>

<ul class="space-y-2">
  <% @articles.each do |article| %>
    <li>
      <%= link_to article.title, article, class: "text-blue-500 hover:underline" %>
    </li>
  <% end %>
</ul>

<div class="mt-4">
  <%= link_to "New Article", new_article_path, class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
</div>
