<h1 class="text-3xl font-bold mb-6">Notes</h1>

<div class="mb-4">
  <%= link_to "Create Note", new_note_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
</div>

<p class="text-lg mb-4">Your Points: <span class="font-semibold"><%= current_user.points %></span></p>

<div id="notes-list" class="space-y-4">
  <%= turbo_frame_tag "notes" do %>
    <%= render @notes %>
  <% end %>
</div>
