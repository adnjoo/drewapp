<h1>Chat with OpenAI</h1>

<%= form_with url: chats_create_path, method: :post, data: { turbo: false } do |form| %>
  <div class="field">
    <%= form.label :prompt, "Enter your message" %><br>
    <%= form.text_area :prompt, rows: 5, cols: 40 %>
  </div>

  <div class="field">
    <%= form.label :model, "Choose a model" %><br>
    <%= form.select :model, options_for_select([["GPT-4o-mini", "gpt-4o-mini"], ["GPT-4o", "gpt-4o"]], @selected_model) %>
  </div>

  <div class="actions">
    <%= form.submit "Send" %>
  </div>
<% end %>

<% if @response.present? %>
  <h3>Response:</h3>
  <div>
    <%= markdown(@response) %>
  </div>
<% end %>
